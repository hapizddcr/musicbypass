# ===========================================
# Database
# ===========================================
DATABASE_URL="postgresql://audioforge:audioforge@localhost:5432/audioforge?schema=public"

# ===========================================
# Auth.js
# ===========================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Discord OAuth
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ===========================================
# Cloudflare R2 (S3-compatible)
# ===========================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="audioforge-uploads"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"
R2_ENDPOINT="https://xxx.r2.cloudflarestorage.com"

# ===========================================
# Midtrans
# ===========================================
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_NOTIFICATION_URL="http://localhost:3000/api/payment/webhook"

# ===========================================
# App
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AudioForge"

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="60"

# ===========================================
# Worker
# ===========================================
WORKER_CONCURRENCY="2"
